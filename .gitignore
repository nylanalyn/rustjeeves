# Rust build artifacts (workspace + each standalone module crate)
/target/
modules-src/*/target/

# Built modules are artifacts; rebuild from modules-src/ and copy in.
modules/*.wasm

# Runtime SQLite database(s)
*.db
*.db-wal
*.db-shm
*.db-journal

# Runtime theme file (generated with defaults on first use)
/theme.toml

# Test, coverage, and profiling output
__pycache__/
*.profraw
*.profdata
lcov.info
coverage/
perf.data
perf.data.old
flamegraph.svg

# Editor, OS, and temporary files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
.serena/
backups/
bot.db
IDEAS.md
